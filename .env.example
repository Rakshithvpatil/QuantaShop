# SwiftPulse environment variables
# Copy this to .env and fill in your values

# BigCommerce (free sandbox — sign up at devtools.bigcommerce.com)
BC_STORE_HASH=your_store_hash_here
BC_AUTH_TOKEN=your_auth_token_here
BC_API_BASE=https://api.bigcommerce.com/stores

# Kafka
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_ORDERS_TOPIC=bc-orders
KAFKA_SENSOR_TOPIC=wearable-telemetry

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC_TELEMETRY=swiftpulse/wearable/telemetry
MQTT_TOPIC_ALERTS=swiftpulse/wearable/alerts

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# DuckDB
DUCKDB_PATH=./data/swiftpulse.duckdb

# Model names (registered in MLflow)
FORECAST_MODEL_NAME=chronos_demand
ANOMALY_MODEL_NAME=lstm_anomaly

# Ollama (local LLM — install ollama.ai, run: ollama pull mistral)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
